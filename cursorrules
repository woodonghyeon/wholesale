## RPC 함수 (Supabase SQL 에디터에서 실행)

```sql
-- 입고 처리
create or replace function process_stock_in(
  p_product_id   uuid,
  p_business_id  uuid,
  p_warehouse_id uuid,
  p_quantity     int,
  p_unit_price   numeric,
  p_partner_id   uuid default null,
  p_ref_type     text default null,
  p_ref_id       uuid default null,
  p_note         text default null
) returns void language plpgsql as $$
begin
  insert into stock_logs(product_id, business_id, warehouse_id, log_type, quantity,
    unit_price, partner_id, ref_type, ref_id, note)
  values (p_product_id, p_business_id, p_warehouse_id, 'in', p_quantity,
    p_unit_price, p_partner_id, p_ref_type, p_ref_id, p_note);

  insert into inventory(product_id, business_id, warehouse_id, quantity)
  values (p_product_id, p_business_id, p_warehouse_id, p_quantity)
  on conflict (product_id, business_id, warehouse_id)
  do update set quantity = inventory.quantity + p_quantity, updated_at = now();
end;
$$;

-- 출고 처리
create or replace function process_stock_out(
  p_product_id   uuid,
  p_business_id  uuid,
  p_warehouse_id uuid,
  p_quantity     int,
  p_unit_price   numeric,
  p_partner_id   uuid default null,
  p_channel_id   uuid default null,
  p_staff_id     uuid default null,
  p_ref_type     text default null,
  p_ref_id       uuid default null,
  p_log_type     text default 'out',
  p_note         text default null
) returns void language plpgsql as $$
declare v_stock int;
begin
  select quantity into v_stock from inventory
  where product_id=p_product_id and business_id=p_business_id and warehouse_id=p_warehouse_id;

  if coalesce(v_stock,0) < p_quantity then
    raise exception '재고 부족: 현재고=%, 요청=%', coalesce(v_stock,0), p_quantity;
  end if;

  insert into stock_logs(product_id, business_id, warehouse_id, log_type, quantity,
    unit_price, partner_id, channel_id, staff_id, ref_type, ref_id, note)
  values (p_product_id, p_business_id, p_warehouse_id, p_log_type, p_quantity,
    p_unit_price, p_partner_id, p_channel_id, p_staff_id, p_ref_type, p_ref_id, p_note);

  update inventory
  set quantity = quantity - p_quantity, updated_at = now()
  where product_id=p_product_id and business_id=p_business_id and warehouse_id=p_warehouse_id;
end;
$$;

-- 재고 조정 (실사)
create or replace function process_stock_adjustment(
  p_product_id   uuid,
  p_business_id  uuid,
  p_warehouse_id uuid,
  p_new_quantity int,
  p_note         text default null
) returns void language plpgsql as $$
declare v_diff int; v_current int;
begin
  select quantity into v_current from inventory
  where product_id=p_product_id and business_id=p_business_id and warehouse_id=p_warehouse_id;
  v_diff := p_new_quantity - coalesce(v_current, 0);

  insert into stock_logs(product_id, business_id, warehouse_id, log_type, quantity, note)
  values (p_product_id, p_business_id, p_warehouse_id, 'adjustment', v_diff, p_note);

  insert into inventory(product_id, business_id, warehouse_id, quantity)
  values (p_product_id, p_business_id, p_warehouse_id, p_new_quantity)
  on conflict (product_id, business_id, warehouse_id)
  do update set quantity = p_new_quantity, updated_at = now();
end;
$$;

-- 반품 재입고
create or replace function process_stock_return_in(
  p_product_id   uuid,
  p_business_id  uuid,
  p_warehouse_id uuid,
  p_quantity     int,
  p_return_id    uuid default null
) returns void language plpgsql as $$
begin
  insert into stock_logs(product_id, business_id, warehouse_id, log_type, quantity, ref_type, ref_id)
  values (p_product_id, p_business_id, p_warehouse_id, 'return_in', p_quantity, 'return', p_return_id);

  insert into inventory(product_id, business_id, warehouse_id, quantity)
  values (p_product_id, p_business_id, p_warehouse_id, p_quantity)
  on conflict (product_id, business_id, warehouse_id)
  do update set quantity = inventory.quantity + p_quantity, updated_at = now();
end;
$$;

-- 번들 출고 (원자적 처리)
create or replace function process_bundle_out(
  p_bundle_product_id uuid,
  p_business_id       uuid,
  p_warehouse_id      uuid,
  p_bundle_quantity   int,
  p_sell_price        numeric,
  p_channel_id        uuid default null,
  p_ref_id            uuid default null
) returns void language plpgsql as $$
declare comp record; v_stock int; v_need int;
begin
  for comp in select bi.component_product_id, bi.quantity as unit_qty
              from bundle_items bi where bi.bundle_product_id = p_bundle_product_id
  loop
    v_need := comp.unit_qty * p_bundle_quantity;
    select quantity into v_stock from inventory
    where product_id=comp.component_product_id and business_id=p_business_id and warehouse_id=p_warehouse_id;
    if coalesce(v_stock,0) < v_need then
      raise exception '구성품 재고 부족: product_id=%, 현재고=%, 필요=%',
        comp.component_product_id, coalesce(v_stock,0), v_need;
    end if;
  end loop;

  for comp in select bi.component_product_id, bi.quantity as unit_qty
              from bundle_items bi where bi.bundle_product_id = p_bundle_product_id
  loop
    v_need := comp.unit_qty * p_bundle_quantity;
    insert into stock_logs(product_id, business_id, warehouse_id, log_type, quantity, note)
    values (comp.component_product_id, p_business_id, p_warehouse_id, 'bundle_out', v_need, '번들출고구성품');
    update inventory set quantity = quantity - v_need, updated_at = now()
    where product_id=comp.component_product_id and business_id=p_business_id and warehouse_id=p_warehouse_id;
  end loop;

  insert into stock_logs(product_id, business_id, warehouse_id, log_type, quantity,
    unit_price, channel_id, ref_type, ref_id)
  values (p_bundle_product_id, p_business_id, p_warehouse_id, 'out', p_bundle_quantity,
    p_sell_price, p_channel_id, 'slip', p_ref_id);
end;
$$;
